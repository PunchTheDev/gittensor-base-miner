+    },
+    queueHealth: { level: "high", burdenScore: 88, reviewablePullRequests: 0, summary: "Queue burden is high." },
+    contributorIntakeHealth: {
+      repoFullName: "octo/test",
+      generatedAt: "2026-05-28T00:00:00.000Z",
+      level: "healthy",
+      score: 90,
+      queueHealth: {
+        burdenScore: 88,
+        level: "high",
+        signals: {
+          openIssues: 4,
+          openPullRequests: 6,
+          unlinkedPullRequests: 1,
