+        let compacted_body =
+            self.serialize_body(&compacted_messages, max_tokens, stream, response_format)?;
+        Ok(PreparedChatBody {
+            body: compacted_body,
+            compacted: true,
+        })
+    }
+
+    fn serialize_body(
