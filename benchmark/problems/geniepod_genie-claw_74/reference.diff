+fn compact_genie_runtime_messages(messages: &[Message]) -> Vec<Message> {
+    let Some(message) = messages
+        .iter()
+        .rev()
+        .find(|m| m.role == "user")
+        .or_else(|| messages.iter().rev().find(|m| m.role != "system"))
+    else {
+        return Vec::new();
+    };
+
+    vec![Message {
+        role: "user".into(),
+        content: format!("{}\n\n{}", GENIE_RUNTIME_COMPACT_SYSTEM, message.content),
+    }]
+}
