+        + [f"x-tab:   {name}\t{name}".encode() for name in ("x", "y", "z", "q")]
+        + [
+            f"Cookie:   {c}={c * 26}".encode()
+            for c in "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
+        ]
