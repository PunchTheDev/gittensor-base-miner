+        // Library top-first: one enchantment + four instants within the milled top-5.
+        let milled_enchantment = create_object(
+            &mut state,
+            CardId(1),
+            PlayerId(0),
+            "Milled Aura".to_string(),
+            Zone::Library,
+        );
+        mark_enchantment(&mut state, milled_enchantment);
