+    assert_difference "KrakenItem.count", 1 do
+      post kraken_items_url, params: {
+        kraken_item: {
+          name: "Joint Kraken",
+          api_key: "joint_kraken_key",
+          api_secret: "joint_kraken_secret"
+        }
+      }
+    end
