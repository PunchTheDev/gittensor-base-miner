+                {"chunk_id": "chunk2", "content": "test2", "kb_id": "kb1"},
+            ]
+        }
+        rows = mod.ChunkFeedbackService._feedback_rows_from_reference(reference)
+        assert [r[0] for r in rows] == ["chunk1", "chunk2"]
