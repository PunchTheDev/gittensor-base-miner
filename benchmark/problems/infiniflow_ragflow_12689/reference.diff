+    def test_reference_with_no_chunks(self, feedback_env):
+        mod, _ = feedback_env
+        reference = {"doc_aggs": [{"doc_id": "doc1"}]}
+        assert mod.ChunkFeedbackService._feedback_rows_from_reference(reference) == []
