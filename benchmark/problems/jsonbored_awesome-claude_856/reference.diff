diff --git a/apps/web/src/lib/skill-package-validator.ts b/apps/web/src/lib/skill-package-validator.ts
index 883bf6be65..39aacc9cc4 100644
--- a/apps/web/src/lib/skill-package-validator.ts
+++ b/apps/web/src/lib/skill-package-validator.ts
@@ -44,7 +44,10 @@ function normalizePackagePath(value: string) {
     .replace(/\\/g, "/")
     .replace(/^\/+/, "")
     .split("/")
-    .filter(Boolean)
+    // Drop "." segments so a "./scripts/foo" reference resolves to the same
+    // path as "scripts/foo". ".." is kept so the existing unsafe-path guard
+    // still rejects traversal.
+    .filter((segment) => Boolean(segment) && segment !== ".")
     .join("/");
 }
 
