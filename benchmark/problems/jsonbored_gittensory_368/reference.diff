+export type RepoQueueTrendSnapshotRecord = {
+  repoFullName: string;
+  payload: Record<string, JsonValue>;
+  generatedAt: string;
+};
+
 export type PullRequestDetailSyncStateRecord = {
   repoFullName: string;
   pullNumber: number;
