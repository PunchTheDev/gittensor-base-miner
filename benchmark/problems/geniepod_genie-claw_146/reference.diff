+    #[cfg(unix)]
+    #[test]
+    fn audit_logger_read_returns_empty_when_file_unreadable() {
+        use std::os::unix::fs::PermissionsExt;
+
+        let path = std::env::temp_dir().join(format!(
+            "geniepod-actuation-audit-unreadable-{}.jsonl",
