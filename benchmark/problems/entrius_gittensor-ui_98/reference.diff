+    ];
+    const counts = countPrTiers(prs, repoTiers);
+    expect(counts.all).toBe(3);
+    expect(counts.gold).toBe(1);
+    expect(counts.silver).toBe(1);
+    expect(counts.bronze).toBe(1);
+  });
+
+  it('handles empty array', () => {
