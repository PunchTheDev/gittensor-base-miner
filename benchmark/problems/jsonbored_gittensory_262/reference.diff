+  return sources
+    .slice(0, 4)
+    .map((source) => source.label)
+    .join("; ");
+}
+
+function askSourcesFromContextSnapshot(snapshot: AgentRunBundle["contextSnapshots"][number]): AskContributingSource[] {
+  const payload = snapshot.payload ?? {};
