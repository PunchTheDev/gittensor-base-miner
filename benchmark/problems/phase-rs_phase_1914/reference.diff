+    let unknown_cards = collect_unknown_cards(db, request);
+    let check = evaluate_oathbreaker(db, request, &unknown_cards);
+    QuickCheckResult {
+        reason: check.reasons.into_iter().next(),
+        unknown_cards,
+    }
+}
