+export type AiRewriteRequest = {
+  feature: string;
+  visibility: AiSummaryVisibility;
+  bundle: Record<string, JsonValue>;
+  fallbackText: string;
+  instructions: string;
+  actor?: string | null | undefined;
+  route?: string | null | undefined;
