diff --git a/changelog/14492.bugfix.rst b/changelog/14492.bugfix.rst
new file mode 100644
index 00000000000..1e5c6b778d3
--- /dev/null
+++ b/changelog/14492.bugfix.rst
@@ -0,0 +1 @@
+Fixed ``Code.getargs()`` incorrectly including local variable names in the returned argument tuple for functions with ``*args`` and/or ``**kwargs``. The method was using ``co_flags`` bitmask values (``4`` and ``8``) directly as counts instead of converting them to ``1`` via ``bool()``, and was not accounting for ``co_kwonlyargcount`` when ``var=True``.
diff --git a/src/_pytest/_code/code.py b/src/_pytest/_code/code.py
index 4cf99a77340..4fcce0427ef 100644
--- a/src/_pytest/_code/code.py
+++ b/src/_pytest/_code/code.py
@@ -121,8 +121,9 @@ def getargs(self, var: bool = False) -> tuple[str, ...]:
         raw = self.raw
         argcount = raw.co_argcount
         if var:
-            argcount += raw.co_flags & CO_VARARGS
-            argcount += raw.co_flags & CO_VARKEYWORDS
+            argcount += raw.co_kwonlyargcount
+            argcount += bool(raw.co_flags & CO_VARARGS)
+            argcount += bool(raw.co_flags & CO_VARKEYWORDS)
         return raw.co_varnames[:argcount]
 
 
