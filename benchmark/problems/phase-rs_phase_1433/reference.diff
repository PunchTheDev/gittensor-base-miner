+#[test]
+fn dig_up_cleave_searches_any_card_without_reveal() {
+    let mut scenario = GameScenario::new();
+    scenario.at_phase(Phase::PreCombatMain);
+    let spell = cleave_spell_in_hand(
+        &mut scenario,
+        "Dig Up",
+        DIG_UP,
+        ManaCost::Cost {
+            shards: vec![
+                ManaCostShard::Black,
+                ManaCostShard::Black,
+                ManaCostShard::Green,
+            ],
+            generic: 1,
+        },
+        true,
+    );
+    let mut runner = scenario.build();
