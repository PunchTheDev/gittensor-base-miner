+
+    expect_correction(<<~'RUBY')
+      "this is \" silly"
+    RUBY
+  end
+
+  it 'handles escaped interpolation text in double quotes when autocorrecting' do
+    expect_offense(<<~'RUBY')
+      "this is #{"\#{1}"} silly"
+                 ^^^^^^^ Literal interpolation detected.
+    RUBY
+
+    expect_correction(<<~'RUBY')
+      "this is \#{1} silly"
+    RUBY
+  end
