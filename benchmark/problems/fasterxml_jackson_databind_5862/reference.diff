diff --git a/src/main/java/tools/jackson/databind/deser/jackson/JsonNodeDeserializer.java b/src/main/java/tools/jackson/databind/deser/jackson/JsonNodeDeserializer.java
index 0555977799..d9441c763d 100644
--- a/src/main/java/tools/jackson/databind/deser/jackson/JsonNodeDeserializer.java
