+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+enum RequestRoute<'a> {
+    Root,
+    ChatStream,
+    Chat,
+    History,
+    Clear,
+    Conversations,
+    Tools,
+    RuntimeContract,
+    WebSearchStatus,
