+)
+def test_is_test_file_detects_rspec_conventions(filename):
+    assert _file_change(filename).is_test_file() is True
+
+
+@pytest.mark.parametrize(
+    'filename',
+    [
+        'app/build.gradle.kts',
+        'src/main/java/com/example/Bar.java',
