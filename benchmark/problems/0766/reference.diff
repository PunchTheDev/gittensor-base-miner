+        'app/models/specification.rb',
+        'lib/spectrum.rb',
+        'config/spec.rb',
+    ],
+)
+def test_is_test_file_rejects_non_test_lookalikes(filename):
+    assert _file_change(filename).is_test_file() is False
+
+
+def test_is_test_file_preserves_existing_test_conventions():
