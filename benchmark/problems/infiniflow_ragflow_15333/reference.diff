+# ---------------------------------------------------------------------------
+# Non-2xx Graph responses must raise (no silent partial syncs)
+# ---------------------------------------------------------------------------
+
+def _ok(json_value):
+    resp = MagicMock(ok=True, status_code=200)
+    resp.json.return_value = json_value
+    return resp
+
+
+def _err(status, text=""):
+    resp = MagicMock(ok=False, status_code=status)
+    resp.text = text
+    return resp
+
