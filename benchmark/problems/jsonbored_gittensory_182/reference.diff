+      sessionId: "gts_session_secret",
+      route: "/v1/app/commands/preview",
+      repoFullName: "oktofeesh1/private-tool",
+      targetKey: "Oktofeesh1:private-tool#136",
+      outcome: "success",
+      metadata: { command: "packet", viewer: "Oktofeesh1", nested: { note: "for oktofeesh1" } },
+    });
