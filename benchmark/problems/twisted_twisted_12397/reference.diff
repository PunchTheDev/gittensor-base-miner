+    """
+
+    @classmethod
+    def new(
+        cls,
+        reactor: IReactorTCP,
+        url: str,
+        tlsPolicy: IPolicyForHTTPS = BrowserLikePolicyForHTTPS(),
+        connectTimeout: int | None = None,
+        bindAddress: bytes | None = None,
+    ) -> WebSocketClientEndpoint:
+        """
