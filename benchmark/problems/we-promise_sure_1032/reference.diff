+  test "same plaid_id cannot appear twice under the same plaid_item" do
+    PlaidAccount.create!(
+      plaid_item: @item_a,
+      plaid_id: "duplicate_plaid",
+      name: "Checking",
+      plaid_type: "depository",
+      currency: "USD",
+      current_balance: 1000
+    )
+
+    duplicate = PlaidAccount.new(
+      plaid_item: @item_a,
+      plaid_id: "duplicate_plaid",
+      name: "Checking",
+      plaid_type: "depository",
+      currency: "USD",
+      current_balance: 1000
+    )
+    refute duplicate.valid?
