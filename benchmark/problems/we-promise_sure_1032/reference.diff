+
+    assert_raises(ActiveRecord::RecordInvalid) do
+      PlaidAccount.create!(
+        plaid_item: @item_a,
+        plaid_id: "duplicate_plaid",
+        name: "Checking",
+        plaid_type: "depository",
+        currency: "USD",
+        current_balance: 1000
+      )
+    end
+  end
+end
