+        || take_until::<_, _, OracleError<'_>>(",")
+            .parse(materials_text)
+            .is_ok()
+    {
+        return None;
+    } else {
+        let (filter, rest) = parse_type_phrase(materials_text);
+        if !rest.trim().is_empty() {
