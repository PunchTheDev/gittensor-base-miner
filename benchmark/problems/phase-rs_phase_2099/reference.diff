+fn parse_craft_materials(input: &str) -> Option<(&str, (TargetFilter, CostObjectCount))> {
+    let (cost_text, materials_text) = take_until::<_, _, OracleError<'_>>("{").parse(input).ok()?;
+    let materials_text = materials_text.trim();
