+
+fn parse_craft_relative_material_clause(input: &str) -> nom::IResult<&str, (), OracleError<'_>> {
+    let (rest, _) = tag("that").parse(input)?;
+    let (rest, _) = alt((value((), space1), value((), eof))).parse(rest)?;
+    Ok((rest, ()))
