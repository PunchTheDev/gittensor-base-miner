+        if display_currency == "USD" && USD_STABLECOINS.include?(base)
+          return { binance_pair: nil, base: base, display_currency: "USD", stablecoin: true }
+        end
+
         return { binance_pair: "#{base}#{quote}", base: base, display_currency: display_currency }
       end
-      nil
