+            spec.extras.forEach { (key, value) ->
+                putExtra(key, value.replace(SettingsPanelIntent.AppPackagePlaceholder, packageName))
+            }
+        }
+        return try {
+            context.startActivity(intent)
+            record(
+                "open_settings_panel",
+                "panel=\"${spec.panel}\"",
