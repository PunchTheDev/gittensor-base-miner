+
+    let client = TestClient::new(router);
+
+    let res = client.get("/").await;
+    let body = res.text().await;
+    assert_eq!(body, "fallback1");
+
+    let res = client.get("/x").await;
+    let body = res.text().await;
+    assert_eq!(body, "fallback1");
