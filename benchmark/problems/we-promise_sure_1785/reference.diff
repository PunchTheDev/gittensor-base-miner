+            example.run
+          end
+        end
+
+        run_test!
+      end
+
+      response '404', 'import session not found' do
+        schema '$ref' => '#/components/schemas/ErrorResponse'
+
+        let(:id) { SecureRandom.uuid }
+
+        run_test!
+      end
+    end
+  end
+end
