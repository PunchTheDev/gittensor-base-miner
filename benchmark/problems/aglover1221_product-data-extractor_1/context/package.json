{
  "name": "product-data-extractor",
  "version": "0.1.0",
  "description": "Studio for product data extraction — viewer, schema-walked LLM extraction (Anthropic Batch), PDF parsing (Reducto), and pipeline orchestration. Reads a configurable data root.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 3210",
    "dev:all": "concurrently -n web,worker -c blue,green \"npm run dev\" \"npm run worker\"",
    "build": "next build",
    "start": "next start -p 3210",
    "worker": "tsx worker/index.ts",
    "studio:init": "tsx scripts/init-studio-db.ts",
    "studio:seed": "tsx scripts/seed-from-filesystem.ts",
    "extract-one": "tsx scripts/extract-one.ts",
    "audit": "tsx scripts/audit-cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@codemirror/commands": "^6.6.2",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.1",
    "better-sqlite3": "^11.5.0",
    "diff": "^5.2.0",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "next": "^14.2.18",
    "pdf-parse": "^1.1.1",
    "pdf-to-png-converter": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/diff": "^5.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
