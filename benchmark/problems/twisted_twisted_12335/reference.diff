@@ -64,3 +69,76 @@ def test_unicodeAndBytes(self) -> None:
         self.assertFalse(isIPv6Address("\u4321"))
         self.assertFalse(isIPv6Address("hello%eth0"))
         self.assertFalse(isIPv6Address(b"hello%eth0"))  # type: ignore[arg-type]
+
